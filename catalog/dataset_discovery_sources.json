      "native_format": "csv.zst",
      "file_url_regex": "ais-(?P<version>\\d{4}-\\d{2}-\\d{2})\\.csv\\.zst$",
      "categories": [
        "ais",
        "maritime",
        "vessel_traffic",
        "gis",
        "timeseries"
