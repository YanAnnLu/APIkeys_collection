      "capability_targets": [
        "identity_only_future"
      ]
    },
    {
      "id": "microsoft",
      "label": "Microsoft",
      "auth_mode": "oauth_device_qr",
      "status": "reserved",
      "capability_targets": [
        "identity_only_future",
        "azure_openai_future",
        "onedrive_future"
      ]
    }
  ],
