{
  "schema_version": 1,
  "active_database_client": "mysql_workbench",
  "active_ai_summary_profile": "local_ollama",
  "active_download_tool": "python_internal",
  "active_unreal_project": "local_ue5_bridge",
  "ui_language": "zh-TW",
  "download_policy": {
    "max_parallel_jobs": 3,
    "max_parallel_per_host": 1,
    "min_delay_per_host_seconds": 1.0,
    "max_retries": 5,
    "retry_base_delay_seconds": 2.0,
    "retry_max_delay_seconds": 120.0,
    "cooldown_status_codes": [
      429,
      503
    ],
    "user_agent": "APIkeys_collection/0.3 (+polite-downloader; contact: local-user)"
  },
  "database_clients": [
    {
      "id": "mysql_workbench",
      "label": "MySQL Workbench",
      "kind": "mysql",
      "enabled": true,
      "command_by_platform": {
        "Windows": [
          "C:\\Program Files\\MySQL\\MySQL Workbench 8.0\\MySQLWorkbench.exe"
        ],
        "Darwin": [
          "open",
          "-a",
          "MySQLWorkbench"
        ],
        "Linux": [
          "mysql-workbench"
        ]
      },
      "notes": "Copy this file to launcher_integrations.local.json and adjust paths for your machine."
    },
    {
      "id": "dbeaver",
      "label": "DBeaver",
      "kind": "universal_sql",
      "enabled": false,
      "command_by_platform": {
        "Windows": [
          "C:\\Program Files\\DBeaver\\dbeaver.exe"
        ],
        "Darwin": [
          "open",
          "-a",
          "DBeaver"
        ],
        "Linux": [
          "dbeaver"
        ]
      },
      "notes": "Cross-database fallback for MySQL, PostgreSQL, SQLite, and more."
    }
  ],
  "data_store_connection_profiles": [
    {
      "id": "mysql_default",
      "label": "MySQL default",
      "store_kind": "relational_sql",
      "engine": "mysql",
      "required_env_vars": [
        "APIKEYS_MYSQL_HOST",
        "APIKEYS_MYSQL_DATABASE",
        "APIKEYS_MYSQL_USER",
        "APIKEYS_MYSQL_PASSWORD"
      ],
      "optional_env_vars": [
        "APIKEYS_MYSQL_PORT"
      ],
      "env_var_map": {
        "host": "APIKEYS_MYSQL_HOST",
        "database": "APIKEYS_MYSQL_DATABASE",
        "user": "APIKEYS_MYSQL_USER",
        "password": "APIKEYS_MYSQL_PASSWORD",
        "port": "APIKEYS_MYSQL_PORT"
      },
      "notes": "Passwords should come from environment variables or a future credential vault, not Git-tracked config."
    },
    {
      "id": "postgres_default",
      "label": "PostgreSQL default",
      "store_kind": "relational_sql",
      "engine": "postgresql",
      "required_env_vars": [
        "APIKEYS_POSTGRES_HOST",
        "APIKEYS_POSTGRES_DATABASE",
        "APIKEYS_POSTGRES_USER",
        "APIKEYS_POSTGRES_PASSWORD"
      ],
      "optional_env_vars": [
        "APIKEYS_POSTGRES_PORT"
      ],
      "env_var_map": {
        "host": "APIKEYS_POSTGRES_HOST",
        "database": "APIKEYS_POSTGRES_DATABASE",
        "user": "APIKEYS_POSTGRES_USER",
        "password": "APIKEYS_POSTGRES_PASSWORD",
        "port": "APIKEYS_POSTGRES_PORT"
      },
      "notes": "Reserved for PostgreSQL introspection."
    },
    {
      "id": "sqlite_local",
      "label": "SQLite local",
      "store_kind": "embedded_sql",
      "engine": "sqlite",
      "required_env_vars": [
        "APIKEYS_SQLITE_PATH"
      ],
      "env_var_map": {
        "path": "APIKEYS_SQLITE_PATH"
      },
      "notes": "Local file-backed SQLite path for lightweight testing."
    },
    {
      "id": "mongodb_default",
      "label": "MongoDB default",
      "store_kind": "document_nosql",
      "engine": "mongodb",
      "required_env_vars": [
        "APIKEYS_MONGODB_URI"
      ],
      "notes": "Reserved for JSON/document collections."
    },
    {
      "id": "s3_compatible_default",
      "label": "S3-compatible object store",
      "store_kind": "object_storage",
      "engine": "s3_compatible",
      "required_env_vars": [
        "APIKEYS_S3_ENDPOINT",
        "APIKEYS_S3_BUCKET",
        "APIKEYS_S3_ACCESS_KEY",
        "APIKEYS_S3_SECRET_KEY"
      ],
      "notes": "Reserved for data lakes and large raw/curated assets."
    },
    {
      "id": "vector_db_default",
      "label": "Vector DB default",
      "store_kind": "vector_database",
      "engine": "generic_vector_db",
      "required_env_vars": [
        "APIKEYS_VECTOR_DB_ENDPOINT",
        "APIKEYS_VECTOR_DB_API_KEY"
      ],
      "notes": "Reserved for semantic search and local LLM workflows."
    }
  ],
  "download_tools": [
    {
      "id": "python_internal",
      "label": "Python internal downloader",
      "kind": "python_internal",
      "enabled": true,
      "command": [],
      "supports_resume": true,
      "supports_parallel": true,
      "notes": "Default orchestrated downloader. Best for API adapters, authentication, validation, and UI progress."
    },
    {
      "id": "aria2c",
      "label": "aria2c",
      "kind": "external_cli",
      "enabled": false,
      "command_by_platform": {
        "Windows": [
          "aria2c.exe"
        ],
        "Darwin": [
          "aria2c"
        ],
        "Linux": [
          "aria2c"
        ]
      },
      "supports_resume": true,
      "supports_parallel": true,
      "notes": "Strong candidate for large HTTP/FTP files with segmented download, resume, and retries."
    },
    {
      "id": "curl",
      "label": "curl",
      "kind": "external_cli",
      "enabled": false,
      "command_by_platform": {
        "Windows": [
          "curl.exe"
        ],
        "Darwin": [
          "curl"
        ],
        "Linux": [
          "curl"
        ]
      },
      "supports_resume": true,
      "supports_parallel": false,
      "notes": "Portable fallback for direct URLs. Useful when aria2c is unavailable."
    }
  ],
  "ai_summary_profiles": [
    {
      "id": "local_ollama",
      "label": "Local Ollama",
      "kind": "ollama",
      "enabled": true,
      "model": "gemma3:1b",
      "endpoint": "http://localhost:11434/api/generate",
      "notes": "No login required. Install Ollama and pull a small model, or change this model name in launcher_integrations.local.json."
    },
    {
      "id": "gemini_flash",
      "label": "Gemini Flash",
      "kind": "gemini",
      "enabled": false,
      "model": "gemini-2.0-flash",
      "endpoint": "https://generativelanguage.googleapis.com/v1beta/models/{model}:generateContent",
      "api_key_env": "GEMINI_API_KEY",
      "oauth_token_env": "GOOGLE_OAUTH_ACCESS_TOKEN",
      "token_store": "state/private/ai_oauth_tokens/gemini_flash.json",
      "oauth_device": {
        "enabled": true,
        "provider": "google",
        "client_id_env": "GOOGLE_OAUTH_CLIENT_ID",
        "client_secret_env": "GOOGLE_OAUTH_CLIENT_SECRET",
        "device_code_url": "https://oauth2.googleapis.com/device/code",
        "token_url": "https://oauth2.googleapis.com/token",
        "verification_url": "https://www.google.com/device",
        "scopes": [
          "https://www.googleapis.com/auth/cloud-platform",
          "https://www.googleapis.com/auth/generative-language.retriever"
        ],
        "token_env": "GOOGLE_OAUTH_ACCESS_TOKEN",
        "token_store": "state/private/ai_oauth_tokens/gemini_flash.json"
      },
      "notes": "Optional cloud fallback. Enable API key auth with GEMINI_API_KEY, or set oauth_device.enabled=true plus GOOGLE_OAUTH_CLIENT_ID for QR/device login."
    },
    {
      "id": "openai_compatible",
      "label": "OpenAI-compatible",
      "kind": "openai_compatible",
      "enabled": false,
      "model": "gpt-4.1-mini",
      "endpoint": "https://api.openai.com/v1/chat/completions",
      "api_key_env": "OPENAI_API_KEY",
      "oauth_token_env": "AI_OAUTH_ACCESS_TOKEN_OPENAI_COMPATIBLE",
      "token_store": "state/private/ai_oauth_tokens/openai_compatible.json",
      "oauth_device": {
        "enabled": true,
        "provider": "openai_compatible",
        "client_id_env": "OPENAI_COMPATIBLE_OAUTH_CLIENT_ID",
        "client_secret_env": "OPENAI_COMPATIBLE_OAUTH_CLIENT_SECRET",
        "device_code_url": "",
        "token_url": "",
        "verification_url": "",
        "scopes": [],
        "token_env": "AI_OAUTH_ACCESS_TOKEN_OPENAI_COMPATIBLE",
        "token_store": "state/private/ai_oauth_tokens/openai_compatible.json"
      },
      "notes": "Optional OpenAI-compatible chat completions profile. Use OPENAI_API_KEY, or fill oauth_device endpoints for a compatible provider that supports OAuth device-code QR login."
    }
  ],
  "google_oauth": {
    "enabled": false,
    "client_id_env": "GOOGLE_OAUTH_CLIENT_ID",
    "client_secret_env": "GOOGLE_OAUTH_CLIENT_SECRET",
    "scopes": [
      "https://www.googleapis.com/auth/cloud-platform",
      "https://www.googleapis.com/auth/generative-language.retriever"
    ],
    "token_store": "state/private/google_oauth_tokens.json",
    "login_mode": "device_qr",
    "notes": "QR/device login for Gemini and Google services. Token storage must stay local and ignored by Git. If Google rejects these scopes for device login, use the Gemini API key profile or a desktop OAuth flow."
  },
  "account_link_providers": [
    {
      "id": "google",
      "label": "Google",
      "auth_mode": "oauth_device_qr",
      "status": "skeleton",
      "capability_targets": [
