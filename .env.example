# APIkeys_collection generated template
# Fill only keys you own. Do not commit real secrets.

# Alpha Vantage (alphavantage)
# Docs: https://www.alphavantage.co/documentation/
# Signup: https://www.alphavantage.co/support/#api-key
ALPHAVANTAGE_API_KEY=your_alphavantage_api_key

# Copernicus Climate Data Store API (copernicus_cds)
# Docs: https://cds.climate.copernicus.eu/how-to-api
# Signup: https://cds.climate.copernicus.eu/
CDSAPI_KEY=your_cdsapi_key

# Copernicus Data Space Ecosystem (copernicus_dataspace)
# Docs: https://documentation.dataspace.copernicus.eu/APIs.html
# Signup: https://dataspace.copernicus.eu/
COPERNICUS_DATASPACE_TOKEN=your_copernicus_dataspace_token

# Copernicus Marine Service (copernicus_marine)
# Docs: https://help.marine.copernicus.eu/en/articles/4794731-which-apis-are-provided
# Signup: https://data.marine.copernicus.eu/register
COPERNICUS_MARINE_PASSWORD=your_copernicus_marine_password

# Copernicus Marine Service (copernicus_marine)
# Docs: https://help.marine.copernicus.eu/en/articles/4794731-which-apis-are-provided
# Signup: https://data.marine.copernicus.eu/register
COPERNICUS_MARINE_USERNAME=your_copernicus_marine_username

# EIA Open Data API (eia_open_data)
# Docs: https://www.eia.gov/opendata/documentation.php
# Signup: https://www.eia.gov/opendata/register.php
EIA_API_KEY=your_eia_api_key

# FRED API (fred)
# Docs: https://fred.stlouisfed.org/docs/api/fred/
# Signup: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key

# GeoNames Web Services (geonames)
# Docs: https://www.geonames.org/export/ws-overview.html
# Signup: https://www.geonames.org/login
GEONAMES_USERNAME=your_geonames_username

# Google Earth Engine Data Catalog (google_earth_engine)
# Docs: https://developers.google.com/earth-engine/datasets/catalog/
# Signup: https://code.earthengine.google.com/register
GOOGLE_EARTH_ENGINE_TOKEN=your_google_earth_engine_token

# NASA Open APIs (nasa_open_apis)
# Docs: https://api.nasa.gov/
# Signup: https://api.nasa.gov/
NASA_API_KEY=your_nasa_api_key

