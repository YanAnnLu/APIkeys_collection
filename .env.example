# NASA Earthdata (nasa_earthdata)
# Docs: https://www.earthdata.nasa.gov/learn/use-data/data-use-policy/api
# Signup: https://urs.earthdata.nasa.gov/
NASA_EARTHDATA_TOKEN=your_nasa_earthdata_token

# NASA Earthdata (nasa_earthdata)
# Docs: https://www.earthdata.nasa.gov/learn/use-data/data-use-policy/api
# Signup: https://urs.earthdata.nasa.gov/
NASA_EARTHDATA_USERNAME=your_nasa_earthdata_username

# NOAA NCEI Climate Data Online (noaa_ncei_cdo)
# Docs: https://www.ncei.noaa.gov/cdo-web/webservices/v2
# Signup: https://www.ncei.noaa.gov/cdo-web/token
NOAA_NCEI_CDO_TOKEN=paste_your_own_noaa_ncei_cdo_token_here

# OpenAQ API (openaq)
# Docs: https://docs.openaq.org/
# Signup: https://explore.openaq.org/
OPENAQ_API_KEY=your_openaq_api_key

